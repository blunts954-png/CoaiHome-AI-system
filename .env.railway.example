# ===== Railway runtime =====
SYSTEM_DEBUG=false
SYSTEM_LOG_LEVEL=INFO
SYSTEM_CORS_ALLOWED_ORIGINS=https://YOUR-RAILWAY-APP.up.railway.app,https://admin.yourdomain.com
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ===== Shopify app =====
SHOPIFY_SHOP_URL=your-shop.myshopify.com
SHOPIFY_API_KEY=replace_me
SHOPIFY_API_SECRET=replace_me
SHOPIFY_APP_URL=https://YOUR-RAILWAY-APP.up.railway.app
SHOPIFY_API_VERSION=2024-01
SHOPIFY_SSL_VERIFY=true

# Optional bootstrap if you already have an Admin token
# SHOPIFY_ACCESS_TOKEN=shpat_xxxxx

# ===== CJ Dropshipping =====
CJ_API_TOKEN=replace_me
CJ_API_EMAIL=optional
CJ_API_KEY=optional
CJ_BASE_URL=https://developers.cjdropshipping.com/api2.0/v1
CJ_DEFAULT_COUNTRY=US

# ===== AI =====
AI_PROVIDER=openai
AI_API_KEY=replace_me
AI_MODEL=gpt-4-turbo-preview
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2000

# ===== Store defaults =====
STORE_BRAND_NAME=Your Brand
STORE_NICHE=Home Organization
STORE_TARGET_COUNTRY=US
STORE_CURRENCY=USD
STORE_BASE_MARKUP=2.5
STORE_MIN_PRICE=15
STORE_MAX_PRICE=500
