# ===========================================
# AI DROPSHIPPING AUTOMATION - ENV CONFIG
# ===========================================

# -------------------------------------------
# MIGRATION FROM AUTODS (if previously used)
# -------------------------------------------
# CJ Dropshipping is now the recommended supplier:
# 1. Get your CJ token from: https://cjdropshipping.com/
# 2. Set SYSTEM_SUPPLIER_PLATFORM=cj
# 3. Add your CJ_API_TOKEN (format: email@api@key)
# 4. Leave AUTODS_API_KEY blank or remove it

# -------------------------------------------
# REQUIRED: SHOPIFY STORE CONNECTION (2026 MODERN FLOW)
# -------------------------------------------
# 1. Go to Store Admin -> Settings -> Apps and sales channels -> Develop apps
# 2. Click "Build apps in Dev Dashboard"
# 3. Create app -> Settings -> Credentials
# 4. Copy Client ID and Secret
SHOPIFY_SHOP_URL=coaihome.myshopify.com
SHOPIFY_API_KEY=41d4177eb96e6ba9684b42e7388f9987
SHOPIFY_API_SECRET=your_secret_from_dev_dashboard_here
# System will automatically generate its own token using Client ID and Secret (New in 2026)
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_SSL_VERIFY=true
# SHOPIFY_APP_URL=https://your-app.herokuapp.com

# -------------------------------------------
# REQUIRED: AI API KEY
# -------------------------------------------
# Get from: https://platform.openai.com/api-keys
AI_API_KEY=sk-proj-your-openai-key-here
AI_MODEL=gpt-4o-mini

# -------------------------------------------
# REQUIRED: CJ DROPSHIPPING API (Recommended)
# -------------------------------------------
# Get your CJ API token from: https://cjdropshipping.com/
# Format: email@api@key (e.g., youremail@gmail.com@api@xxxxxxxxxxxxx)
SYSTEM_SUPPLIER_PLATFORM=cj
CJ_API_TOKEN=your_cj_api_token
# CJ_BASE_URL=https://developers.cjdropshipping.com/api2.0/v1

# -------------------------------------------
# OPTIONAL: AUTO DS (Legacy - Not Recommended)
# -------------------------------------------
# Keep blank - CJ is the recommended supplier
# AUTODS_API_KEY=

# -------------------------------------------
# OPTIONAL: SECURITY SETTINGS
# -------------------------------------------
# CORS Allowed Origins - comma-separated list for production
# Leave empty for development (allows all origins)
# Example: https://mystore.myshopify.com,https://mydomain.com
# SYSTEM_CORS_ALLOWED_ORIGINS=

# -------------------------------------------
# OPTIONAL: STORE SETTINGS
# -------------------------------------------
STORE_NICHE=home organization
STORE_BRAND_NAME=CoaiHome
STORE_TARGET_COUNTRY=US
STORE_CURRENCY=USD
STORE_BASE_MARKUP=2.5
STORE_MIN_PRICE=15.0
STORE_MAX_PRICE=500.0

# -------------------------------------------
# OPTIONAL: NOTIFICATIONS
# -------------------------------------------
# NOTIFY_EMAIL_ENABLED=false
# NOTIFY_SMTP_HOST=smtp.gmail.com
# NOTIFY_SMTP_PORT=587
# NOTIFY_SMTP_USER=your_email@gmail.com
# NOTIFY_SMTP_PASSWORD=your_app_password
# NOTIFY_ALERT_EMAIL=your_email@gmail.com
