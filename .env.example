# ===========================================
# AI DROPSHIPPING AUTOMATION - ENV CONFIG
# ===========================================

# -------------------------------------------
# REQUIRED: SHOPIFY STORE CONNECTION
# -------------------------------------------
# Option A: Admin API Token (Easiest - RECOMMENDED)
# Get this from: Shopify Admin → Settings → Apps and sales channels 
# → Develop apps → Create an app → Configuration → Admin API access scopes
# → Install app → Reveal token once
SHOPIFY_SHOP_URL=coaihome.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_admin_api_token_here

# Option B: OAuth App Credentials (For app installation flow)
# Use these if you want others to install your app
# SHOPIFY_API_KEY=b2b850c00fb1ce070799b227e8549aa7
# SHOPIFY_API_SECRET=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
# SHOPIFY_APP_URL=https://your-app.herokuapp.com

# -------------------------------------------
# REQUIRED: AI API KEY
# -------------------------------------------
# Get from: https://platform.openai.com/api-keys
AI_API_KEY=sk-proj-your-openai-key-here
AI_MODEL=gpt-4o-mini

# -------------------------------------------
# OPTIONAL: AUTODS BROWSER LOGIN
# -------------------------------------------
# Only needed if you want to use browser automation
# (Works WITHOUT AutoDS API!)
AUTODS_EMAIL=your_autods_email@example.com
AUTODS_PASSWORD=your_autods_password

# -------------------------------------------
# OPTIONAL: STORE SETTINGS
# -------------------------------------------
STORE_NICHE=home organization
STORE_BRAND_NAME=CoaiHome
STORE_TARGET_COUNTRY=US
STORE_CURRENCY=USD
STORE_BASE_MARKUP=2.5
STORE_MIN_PRICE=15.0
STORE_MAX_PRICE=500.0

# -------------------------------------------
# OPTIONAL: NOTIFICATIONS
# -------------------------------------------
# NOTIFY_EMAIL_ENABLED=false
# NOTIFY_SMTP_HOST=smtp.gmail.com
# NOTIFY_SMTP_PORT=587
# NOTIFY_SMTP_USER=your_email@gmail.com
# NOTIFY_SMTP_PASSWORD=your_app_password
# NOTIFY_ALERT_EMAIL=your_email@gmail.com
