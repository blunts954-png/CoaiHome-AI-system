# Shopify Configuration
SHOPIFY_SHOP_URL=your-store.myshopify.com
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_secret
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token
SHOPIFY_API_VERSION=2024-01

# AutoDS Configuration
AUTODS_API_KEY=your_autods_api_key
AUTODS_BASE_URL=https://api.autods.com
AUTODS_AUTO_FULFILLMENT_ENABLED=true
AUTODS_AUTO_PRICING_ENABLED=true
AUTODS_AUTO_IMPORT_ENABLED=true

# AI/LLM Configuration (OpenAI, Anthropic, or Local)
AI_PROVIDER=openai
AI_API_KEY=your_openai_api_key
AI_MODEL=gpt-4-turbo-preview
AI_TEMPERATURE=0.3
AI_MAX_PRICE_CHANGE_PERCENT=10.0
AI_MIN_PROFIT_MARGIN=30.0
AI_MAX_PRODUCTS_PER_DAY=5
AI_MIN_PRODUCT_RATING=4.0
AI_MAX_SHIPPING_DAYS=14

# Store Configuration
STORE_NICHE=home_decor
STORE_BRAND_NAME=My AI Store
STORE_TARGET_COUNTRY=US
STORE_CURRENCY=USD
STORE_PRIMARY_COLOR=#000000
STORE_SECONDARY_COLOR=#ffffff
STORE_BRAND_TONE=professional
STORE_BASE_MARKUP=2.5
STORE_MIN_PRICE=15.0
STORE_MAX_PRICE=500.0

# Notifications
NOTIFY_EMAIL_ENABLED=false
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=your_email@gmail.com
NOTIFY_SMTP_PASSWORD=your_app_password
NOTIFY_ALERT_EMAIL=alerts@yourdomain.com
NOTIFY_SLACK_ENABLED=false
NOTIFY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
NOTIFY_DAILY_SUMMARY_ENABLED=true

# System Configuration
SYSTEM_DEBUG=false
SYSTEM_LOG_LEVEL=INFO
SYSTEM_DATABASE_URL=sqlite:///./dropshipping_ai.db
SYSTEM_REDIS_URL=redis://localhost:6379/0
SYSTEM_REQUIRE_APPROVAL_FOR_IMPORT=false
SYSTEM_REQUIRE_APPROVAL_FOR_PRICE_CHANGES=false
